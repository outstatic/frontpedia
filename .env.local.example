# Outstatic api key, get one at https://outstatic.com
OUTSTATIC_API_KEY=ost_******************************

# Optional:
OST_GITHUB_ID=
OST_GITHUB_SECRET=
OST_REPO_SLUG=my-blog
OST_REPO_BRANCH=main

# Public site URL used for metadata and social image URL resolution
NEXT_PUBLIC_BASE_URL=https://frontpedia.com

# Google Analytics tracking ID
NEXT_PUBLIC_GA_TRACKING_ID=

# Umami Analytics - https://umami.is
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_HOST=
NEXT_PUBLIC_UMAMI_HOST_URL=
NEXT_PUBLIC_UMAMI_DISABLE_LOCALHOST_TRACKING=true

# Google Sheets Service Account https://theoephraim.github.io/node-google-spreadsheet/#/guides/authentication
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SPREADSHEET_ID=

# Recaptcha - https://www.google.com/recaptcha/admin/create
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Resend - https://resend.com
RESEND_API_KEY=
RESEND_SEGMENT_ID=
# Set to false to hide the subscribe UI and disable the /subscribe endpoint
NEXT_PUBLIC_EMAIL_LIST_ENABLED=true

# Used to alert of new submissions
OWNER_EMAIL=owner@email.com
FROM_EMAIL=noreply@email.com
